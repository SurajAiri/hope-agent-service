# Agent Service — FastAPI Demo — Environment Variables
# Copy this file to .env and adjust for your environment.
# Defaults match docker-compose.yml

# App
LOG_LEVEL=INFO
DEBUG=false

# Redis (docker-compose default)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Postgres (docker-compose maps 5433:5432)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=myapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# MinIO / S3 (docker-compose default)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=agent-runs

# authorization
AUTHORIZATION_SECRET_KEY=supersecretkey